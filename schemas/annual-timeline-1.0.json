                  },
                  "name": {
                    "type": "string"
                  },
                  "elementCode": {
                    "enum": [
                      "WOOD",
                      "FIRE",
                      "EARTH",
                      "METAL",
                      "WATER"
                    ]
                  },
                  "element": {
                    "type": "string"
                  },
                  "polarityCode": {
                    "enum": [
                      "YANG",
                      "YIN"
                    ]
                  },
                  "polarity": {
                    "type": "string"
                  }
                }
              },
              "branch": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "index",
                  "code",
                  "name",
                  "elementCode",
                  "element",
                  "polarityCode",
                  "polarity",
                  "hiddenStems"
                ],
                "properties": {
                  "index": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 11
                  },
                  "code": {
                    "enum": [
                      "ZI",
                      "CHOU",
                      "YIN",
                      "MAO",
                      "CHEN",
                      "SI",
                      "WU",
                      "WEI",
                      "SHEN",
                      "YOU",
                      "XU",
                      "HAI"
                    ]
                  },
                  "name": {
