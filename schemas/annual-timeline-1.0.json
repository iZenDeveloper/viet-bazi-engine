                  },
                  "elementCode": {
                    "enum": [
                      "WOOD",
                      "FIRE",
                      "EARTH",
                      "METAL",
                      "WATER"
                    ]
                  },
                  "element": {
                    "type": "string"
                  },
                  "polarityCode": {
                    "enum": [
                      "YANG",
                      "YIN"
                    ]
                  },
                  "polarity": {
                    "type": "string"
                  },
                  "hiddenStems": {
                    "type": "array",
                    "minItems": 1,
                    "maxItems": 3,
                    "items": {
                      "type": "object",
                      "additionalProperties": false,
                      "required": [
                        "index",
                        "code",
                        "name",
                        "elementCode",
                        "element",
                        "polarityCode",
                        "polarity",
                        "weight",
                        "tenGodCode",
                        "tenGod"
                      ],
                      "properties": {
                        "index": {
                          "type": "integer",
                          "minimum": 0,
                          "maximum": 9
