              },
              "label": {
                "type": "string"
              },
              "stem": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "index",
                  "code",
                  "name",
                  "elementCode",
                  "element",
                  "polarityCode",
                  "polarity"
                ],
                "properties": {
                  "index": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 9
                  },
                  "code": {
                    "enum": [
                      "JIA",
                      "YI",
                      "BING",
                      "DING",
                      "WU",
                      "JI",
                      "GENG",
                      "XIN",
                      "REN",
                      "GUI"
