                        "name": {
                          "type": "string"
                        },
                        "elementCode": {
                          "enum": [
                            "WOOD",
                            "FIRE",
                            "EARTH",
                            "METAL",
                            "WATER"
                          ]
                        },
                        "element": {
                          "type": "string"
                        },
                        "polarityCode": {
                          "enum": [
                            "YANG",
                            "YIN"
                          ]
                        },
                        "polarity": {
                          "type": "string"
                        },
                        "weight": {
                          "type": "number",
                          "minimum": 0,
                          "maximum": 1
                        },
                        "tenGodCode": {
                          "enum": [
                            "BI_JIAN",
                            "JIE_CAI",
                            "SHI_SHEN",
                            "SHANG_GUAN",
                            "PIAN_CAI",
                            "ZHENG_CAI",
                            "QI_SHA",
                            "ZHENG_GUAN",
                            "PIAN_YIN",
                            "ZHENG_YIN"
                          ]
                        },
                        "tenGod": {
                          "type": "string"
                        }
                      }
                    }
                  }
                }
              },
              "tenGodCode": {
                "enum": [
                  "BI_JIAN",
                  "JIE_CAI",
                  "SHI_SHEN",
                  "SHANG_GUAN",
                  "PIAN_CAI",
                  "ZHENG_CAI",
                  "QI_SHA",
                  "ZHENG_GUAN",
                  "PIAN_YIN",
                  "ZHENG_YIN",
                  "DAY_MASTER"
