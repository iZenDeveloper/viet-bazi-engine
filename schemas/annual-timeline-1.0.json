{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://viet-bazi.dev/schema/annual-timeline-1.0.json",
  "title": "Viet Bazi Annual Timeline 1.0",
  "type": "array",
  "minItems": 1,
  "maxItems": 201,
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "year",
      "activeLuck",
      "analysis"
    ],
    "properties": {
      "year": {
        "type": "integer",
        "minimum": 1600,
        "maximum": 2400
      },
      "activeLuck": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "asOfYear",
          "order",
          "pillar"
        ],
        "properties": {
          "asOfYear": {
            "type": "integer",
            "minimum": 1600,
            "maximum": 2400
          },
          "order": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 1,
            "maximum": 8
          },
          "pillar": {
            "type": [
              "object",
              "null"
            ]
          }
        }
      },
      "analysis": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "year",
          "pillar",
          "stemTenGodCode",
          "stemTenGod",
          "interactions",
          "activeLuckInteraction"
