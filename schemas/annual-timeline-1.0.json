              },
              "tenGod": {
                "type": "string"
              }
            }
          },
          "stemTenGodCode": {
            "enum": [
              "BI_JIAN",
              "JIE_CAI",
              "SHI_SHEN",
              "SHANG_GUAN",
              "PIAN_CAI",
              "ZHENG_CAI",
              "QI_SHA",
              "ZHENG_GUAN",
              "PIAN_YIN",
              "ZHENG_YIN"
            ]
          },
